# Environment variables for the Microservices Ports
ORDERS_PORT=3000
AUDIT_PORT=3001
AUDIT_TCP_PORT=4000

# PostgreSQL configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=orders
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# MongoDB configuration
MONGODB_URI=mongodb://mongodb:27017/audit

# Throttling configuration
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=10

# API Key for securing the API's
API_KEY=your-secure-api-key

# Orders service startup test data seeding (set true only for local/dev)
SEED_ORDERS_ON_STARTUP=false
