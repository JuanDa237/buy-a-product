{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/buy-a-product/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/buy-a-product/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/buy-a-product",
  "projects": {
    "audit": {
      "type": "application",
      "root": "apps/audit",
      "entryFile": "main",
      "sourceRoot": "apps/audit/src",
      "compilerOptions": {
        "tsConfigPath": "apps/audit/tsconfig.app.json"
      }
    },
    "buy-a-product": {
      "type": "application",
      "root": "apps/buy-a-product",
      "entryFile": "main",
      "sourceRoot": "apps/buy-a-product/src",
      "compilerOptions": {
        "tsConfigPath": "apps/buy-a-product/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "orders": {
      "type": "application",
      "root": "apps/orders",
      "entryFile": "main",
      "sourceRoot": "apps/orders/src",
      "compilerOptions": {
        "tsConfigPath": "apps/orders/tsconfig.app.json"
      }
    }
  }
}