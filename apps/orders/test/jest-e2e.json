{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "moduleNameMapper": {
    "^@app/common(|/.*)$": "<rootDir>/../../../libs/common/src/$1",
    "^@app/audit-common(|/.*)$": "<rootDir>/../../../libs/audit-common/src/$1",
    "^@app/orders-common(|/.*)$": "<rootDir>/../../../libs/orders-common/src/$1"
  },
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}