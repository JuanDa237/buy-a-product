{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    // baseUrl (deprecated) and paths are required to make the imports work with the most recent version of NestJS
    "baseUrl": "./",
    "paths": {
      "@app/audit-common": [
        "libs/audit-common/src"
      ],
      "@app/audit-common/*": [
        "libs/audit-common/src/*"
      ],
      "@app/common": [
        "libs/common/src"
      ],
      "@app/common/*": [
        "libs/common/src/*"
      ],
      "@app/orders-common": [
        "libs/orders-common/src"
      ],
      "@app/orders-common/*": [
        "libs/orders-common/src/*"
      ]
    },
    "types": [
      "node",
      "jest"
    ]
  }
}